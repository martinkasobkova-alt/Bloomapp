# MongoDB (povinné)
MONGO_URL=mongodb://localhost:27017
DB_NAME=bloom

# JWT (povinné – app neběží bez něj)
JWT_SECRET=your-secret-key-here

# Resend – e-maily (registrace, obnovení hesla)
# Získejte API klíč na https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=noreply@budsva.eu
FRONTEND_URL=https://vase-domena.cz
# Pro vývoj: FRONTEND_URL=http://localhost:3000
# Smazat rate limit ručně: GET nebo POST http://localhost:8000/api/auth/clear-reset-rate-limit (jen z localhost)

# Trusted proxy IPs – X-Forwarded-For/X-Real-IP se bere v úvahu jen když request přichází z těchto IP (např. nginx)
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# Facebook OAuth (volitelné – prázdné = vypnuto)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# VAPID pro push notifikace (volitelné)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_FILE=vapid_private.pem
VAPID_CLAIMS_EMAIL=mailto:noreply@budsva.eu

# Cloudflare Turnstile (anti-spam při registraci)
# Získejte klíče na https://dash.cloudflare.com/?to=/:account/turnstile
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# Cloudinary – media storage (povinné pro upload obrázků/videí)
# Získejte na https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS (povinné – app neběží bez něj, např. http://localhost:3000,https://vase-domena.cz)
CORS_ORIGINS=http://localhost:3000

# Admin bootstrap – tajemství pro /admin/setup-first-admin (pouze pokud ještě neexistuje admin)
ADMIN_SETUP_SECRET=your-admin-setup-secret
