REACT_APP_BACKEND_URL=http://localhost:8000

# Google OAuth: Název "Bloom" se předává jako app_name. Pro produkci nastav redirect na bloomapp.cz.
# REACT_APP_AUTH_REDIRECT_ORIGIN=https://bloomapp.cz
# REACT_APP_AUTH_APP_NAME=Bloom

# Cloudflare Turnstile (anti-spam při registraci)
# Získejte klíče na https://dash.cloudflare.com/?to=/:account/turnstile
# REACT_APP_TURNSTILE_SITE_KEY=0x4AAAAAAA...
