# API URL pro mobilní aplikaci
# Na fyzickém zařízení musí být IP vašeho počítače (ne localhost)
# Příklad: EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
# EXPO_PUBLIC_API_URL=

# Cloudflare Turnstile (anti-spam při registraci)
# EXPO_PUBLIC_WEB_URL=https://bloom.cz
# EXPO_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
